RewriteEngine On

# Enforce one canonical origin for Google and users.
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP_HOST} !^www\.historiskaroster\.se$ [NC]
RewriteRule ^ https://www.historiskaroster.se%{REQUEST_URI} [R=301,L]

# Normalize the explicit index document to the root URL.
RewriteCond %{THE_REQUEST} \s/+index\.html[\s?] [NC]
RewriteRule ^index\.html$ / [R=301,L]

# Serve existing files and directories normally.
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# SPA fallback for Vue Router history mode.
RewriteRule ^ index.html [L]
